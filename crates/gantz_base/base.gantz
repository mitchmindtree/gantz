(graph div
  (expr0 (expr (/ $l $r)))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "number" "quotient"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph empty?
  (expr0 (expr (empty? $list)))
  (inlet1 (inlet "list" "input list"))
  (outlet2 (outlet "boolean" "true if empty"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph eq
  (expr0 (expr (equal? $l $r)))
  (inlet1 (inlet "value" "left value"))
  (inlet2 (inlet "value" "right value"))
  (outlet3 (outlet "boolean" "true if equal"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph first
  (expr0 (expr (car $list)))
  (inlet1 (inlet "list" "input list"))
  (outlet2 (outlet "value" "first element"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph gt
  (expr0 (expr (> $l $r)))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "boolean" "true if left > right"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph gte
  (expr0 (expr (>= $l $r)))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "boolean" "true if left >= right"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph length
  (expr0 (expr (length $list)))
  (inlet1 (inlet "list" "input list"))
  (outlet2 (outlet "number" "element count"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph list-ref
  (expr0 (expr (list-ref $list (exact (round $index)))))
  (inlet1 (inlet "list" "input list"))
  (inlet2 (inlet "number" "zero-based index"))
  (outlet3 (outlet "value" "element at index"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph list?
  (expr0 (expr (list? $x)))
  (inlet1 (inlet "value" "value to test"))
  (outlet2 (outlet "boolean" "true if a list"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph lt
  (expr0 (expr (< $l $r)))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "boolean" "true if left < right"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph lte
  (expr0 (expr (<= $l $r)))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "boolean" "true if left <= right"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph mod
  (expr0 (expr (let
  ((n (exact (round $l)))
   (d (exact (round $r))))
  (if (zero? d) n (modulo n d)))))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "number" "remainder"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph mul
  (expr0 (expr (* $l $r)))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "number" "product"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph neg
  (expr0 (expr (- 0 $x)))
  (inlet1 (inlet "number" "value to negate"))
  (outlet2 (outlet "number" "negated value"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph neq
  (expr0 (expr (not (equal? $l $r))))
  (inlet1 (inlet "value" "left value"))
  (inlet2 (inlet "value" "right value"))
  (outlet3 (outlet "boolean" "true if not equal"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph not
  (expr0 (expr (not $x)))
  (inlet1 (inlet "boolean" "value to invert"))
  (outlet2 (outlet "boolean" "logical negation"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph number?
  (expr0 (expr (number? $x)))
  (inlet1 (inlet "value" "value to test"))
  (outlet2 (outlet "boolean" "true if a number"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph or
  (expr0 (expr (if $l $l $r)))
  (inlet1 (inlet "boolean" "left operand"))
  (inlet2 (inlet "boolean" "right operand"))
  (outlet3 (outlet "boolean" "true if either is truthy"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(graph rest
  (expr0 (expr (cdr $list)))
  (inlet1 (inlet "list" "input list"))
  (outlet2 (outlet "list" "all but the first element"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph reverse
  (expr0 (expr (reverse $list)))
  (inlet1 (inlet "list" "input list"))
  (outlet2 (outlet "list" "reversed list"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph select
  (expr0 (expr (if $cond $then $else)))
  (inlet1 (inlet "boolean" "condition"))
  (inlet2 (inlet "value" "result if true"))
  (inlet3 (inlet "value" "result if false"))
  (outlet4 (outlet "value" "selected value"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> inlet3 (expr0 2))
  (-> expr0 outlet4))

(graph string?
  (expr0 (expr (string? $x)))
  (inlet1 (inlet "value" "value to test"))
  (outlet2 (outlet "boolean" "true if a string"))
  (-> inlet1 expr0)
  (-> expr0 outlet2))

(graph sub
  (expr0 (expr (- $l $r)))
  (inlet1 (inlet "number" "left operand"))
  (inlet2 (inlet "number" "right operand"))
  (outlet3 (outlet "number" "difference"))
  (-> inlet1 expr0)
  (-> inlet2 (expr0 1))
  (-> expr0 outlet3))

(descriptions
  (abs "Absolute value of a number")
  (add "Add two numbers")
  (and "Logical AND of two booleans")
  (append "Concatenate two lists")
  (cons "Prepend an item to a list")
  (demo-all "Demo: a tour of the base nodes")
  (demo-arithmetic "Demo: arithmetic operations")
  (demo-comparison "Demo: comparison operators")
  (demo-list "Demo: list operations")
  (demo-logic "Demo: boolean logic")
  (demo-predicate "Demo: type predicates")
  (div "Divide one number by another")
  (empty? "Whether a list is empty")
  (eq "Whether two values are equal")
  (first "The first item of a list")
  (gt "Whether the left is greater than the right")
  (gte "Whether the left is greater than or equal to the right")
  (length "The number of items in a list")
  (list-ref "The list item at an index")
  (list? "Whether a value is a list")
  (lt "Whether the left is less than the right")
  (lte "Whether the left is less than or equal to the right")
  (mod "Remainder after division")
  (mul "Multiply two numbers")
  (neg "Negate a number")
  (neq "Whether two values differ")
  (not "Logical NOT of a boolean")
  (number? "Whether a value is a number")
  (or "Logical OR of two booleans")
  (rest "A list without its first item")
  (reverse "Reverse a list")
  (select "Choose between two values by a condition")
  (string? "Whether a value is a string")
  (sub "Subtract one number from another"))

